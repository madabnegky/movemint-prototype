# Password for /admin/pricing-model route.
# - Set this in Netlify's environment-variables UI for production.
# - Local dev (npm run dev) bypasses the password gate, so this is only needed
#   if you want to test the gate via `npm run build && npm run start`.
# - Username is hardcoded to "movemint"; change in src/proxy.ts if needed.
ADMIN_PASSWORD=change-me-in-netlify
