# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# NCUA Call Report raw extracts (downloaded by scripts/fetch-ncua.mjs;
# reproducible from the parser, not source). The generated
# src/data/ncua-cus.json IS committed.
/scripts/ncua-tmp/

# Local Claude Code / MCP settings — personal to each dev's machine.
.claude/
.mcp.json

# Local Netlify folder
.netlify

# GT America is licensed (Grilli Type EULA) and this repo is public.
# The font files must not enter version control. They live locally for dev and
# are delivered to Netlify out-of-band (see public/fonts/README.md).
/public/fonts/*.woff2
/public/fonts/*.woff
/public/fonts/*.otf
/public/fonts/*.ttf
